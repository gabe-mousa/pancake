{
  "name": "pancake",
  "version": "1.0.0",
  "description": "Run multiple Claude AI agent sessions side by side in your browser.",
  "type": "module",
  "bin": {
    "pancake": "./bin/pancake.js"
  },
  "files": [
    "bin/",
    "dist/",
    "server/",
    "src/",
    "index.html",
    "vite.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "node bin/pancake.js",
    "dev": "concurrently \"vite\" \"node server/index.js --root . --port 4174\"",
    "dev:full": "concurrently \"vite\" \"node server/index.js --root . --port 4174\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "claude",
    "ai",
    "agents",
    "anthropic",
    "multi-agent"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.2",
    "vite": "^6.0.5"
  }
}
